{
  "name": "tsdown-template",
  "version": "0.1.0",
  "description": "基于 tsdown 的 TypeScript 项目构建模板",
  "author": "CaoMeiYouRen",
  "private": true,
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "cross-env NODE_ENV=production eslint src --fix --ext .ts,.js,.cjs,.mjs",
    "prebuild": "rimraf dist",
    "build": "cross-env NODE_ENV=production tsdown",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "dev:tsdown": "cross-env NODE_ENV=development tsdown --watch",
    "start": "node ./dist/index",
    "start:tsx": "cross-env NODE_ENV=production tsx src/index.ts",
    "release": "semantic-release",
    "commit": "cz",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/debug": "^4.1.13",
    "@types/node": "^25.9.1",
    "commitizen": "^4.3.1",
    "commitlint-config-cmyr": "^1.0.1",
    "conventional-changelog-cmyr-config": "^3.0.0",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog-cmyr": "^2.0.0",
    "debug": "^4.4.3",
    "eslint": "^9.39.2",
    "eslint-config-cmyr": "2.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.2"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog-cmyr"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "npm run lint",
      "git add"
    ]
  },
  "keywords": [
    "tsdown",
    "typescript"
  ],
  "homepage": "https://github.com/CaoMeiYouRen/tsdown-template#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaoMeiYouRen/tsdown-template.git"
  },
  "bugs": {
    "url": "https://github.com/CaoMeiYouRen/tsdown-template/issues"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "type": "module"
}